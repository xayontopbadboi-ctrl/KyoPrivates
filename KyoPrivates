                            humanoid:EquipTool(tool)
                            game:GetService("ReplicatedStorage").RemotesEvent.ChocolateEatEvent:FireServer(tool)
                            task.wait(0.3) 
                        end
                    end
                end
                task.wait(0.1)
            end
