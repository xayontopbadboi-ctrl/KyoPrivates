local Tab = window:AddTab("Combat☠️") -- Name of tab

-- Add the switch to your Tab
Tab:AddSwitch("Auto Kill", function(Value)
    _G.Spawnkill = Value
    if Value then
        task.spawn(function()
            local Players = game:GetService("Players")
            local localPlayer = Players.LocalPlayer
            local ReplicatedStorage = game:GetService("ReplicatedStorage")
            
            while _G.Spawnkill do
                local character = localPlayer.Character
                local rootPart = character and character:FindFirstChild("HumanoidRootPart")
                local humanoid = character and character:FindFirstChildOfClass("Humanoid")

                if character and rootPart and humanoid then
                    -- Handle Tool Equipping/Activating
                    local tool = localPlayer.Backpack:FindFirstChildOfClass("Tool") or character:FindFirstChildOfClass("Tool")
                    if tool then
                        if tool.Parent ~= character then
                            humanoid:EquipTool(tool)
                        end
                        tool:Activate()
                    end

                    -- Target and Teleport
                    for _, player in ipairs(Players:GetPlayers()) do
                        if player ~= localPlayer and player.Character then
                            local tRoot = player.Character:FindFirstChild("HumanoidRootPart")
                            local tHum = player.Character:FindFirstChild("Humanoid")
                            
                            if tRoot and tHum and tHum.Health > 0 then
                                rootPart.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3)
                                break -- Focus on one target at a time
                            end
                        end
                    end
                end

                -- Remote Spam (Size Change)
                local remotes = ReplicatedStorage:FindFirstChild("RemotesEvent")
                if remotes and remotes:FindFirstChild("SizeChanged") then
                    remotes.SizeChanged:FireServer(1)
                end

                task.wait() -- Small delay to prevent crashing
            end
        end)
    end
end)

local TargetName = "" 
local LoopKilling = false

Tab:AddTextBox("Target Player Name", function(text)
    TargetName = text
end, {
    ["placeholder"] = "Enter Username...",
    ["clear"] = false
})

Tab:AddSwitch("TP Kill Target", function(state)
    LoopKilling = state
    if LoopKilling then
        task.spawn(function()
            local localPlayer = game.Players.LocalPlayer
            while LoopKilling do
                local target = game.Players:FindFirstChild(TargetName)
                
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") and 
                   localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    
                    -- 1. Teleport behind the target
                    localPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
                    
                    -- 2. Auto-Equip Logic (If not holding a tool, grab one from backpack)
                    local tool = localPlayer.Character:FindFirstChildOfClass("Tool")
                    if not tool then
                        local backpackTool = localPlayer.Backpack:FindFirstChildOfClass("Tool")
                        if backpackTool then
                            localPlayer.Character.Humanoid:EquipTool(backpackTool)
                            tool = backpackTool
                        end
                    end
                    
                    -- 3. Auto Attack Logic
                    if tool then
                        tool:Activate() -- Swings the sword/uses the tool
                    end
                end
                
                task.wait(0.01) 
            end
        end)
    end
end)

local AutoPunchActive = false
local PunchConn = nil

Tab:AddSwitch("Auto Punch", false, function(Value)
    AutoPunchActive = Value
    
    local player = game.Players.LocalPlayer
    local backpack = player:WaitForChild("Backpack")

    -- 1. Handling the Auto-Equip Logic
    local function EquipPunch(child)
        if AutoPunchActive and child:IsA("Tool") and child.Name == "Punch" then
            task.wait(0.1)
            local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid:EquipTool(child)
            end
        end
    end

    if AutoPunchActive then
        -- Initial equip check
        for _, tool in ipairs(backpack:GetChildren()) do EquipPunch(tool) end
        
        -- Local connection management
        if PunchConn then PunchConn:Disconnect() end
        PunchConn = backpack.ChildAdded:Connect(EquipPunch)
        
        -- 2. Handling the Auto-Click Logic
        task.spawn(function()
            while AutoPunchActive do
                local char = player.Character
                local tool = char and char:FindFirstChild("Punch")
                
                if tool and tool:IsA("Tool") then
                    tool:Activate()
                end
                task.wait(0.1)
            end
        end)
    else
        -- Clean up connection when turned off
        if PunchConn then
            PunchConn:Disconnect()
            PunchConn = nil
        end
    end
end)

