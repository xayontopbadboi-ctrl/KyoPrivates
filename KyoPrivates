-- Auto Chocolates
local AutoEatLoop = false
MainTab:AddSwitch("Auto Chocolates", function(Value)
    AutoEatLoop = Value
    if Value then
        task.spawn(function()
            while AutoEatLoop do
                local player = game.Players.LocalPlayer
                local character = player.Character
                local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                local backpack = player:FindFirstChild("Backpack")

                if humanoid and backpack then
                    for _, tool in pairs(backpack:GetChildren()) do
                        if not AutoEatLoop then break end
                        if tool:IsA("Tool") then
                            humanoid:EquipTool(tool)
                            game:GetService("ReplicatedStorage").RemotesEvent.ChocolateEatEvent:FireServer(tool)
                            task.wait(0.3) 
                        end
                    end
                end
                task.wait(0.1)
            end
        end)
    end
end)
