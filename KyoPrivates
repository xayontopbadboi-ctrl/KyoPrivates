-- Auto Claim Rewards
local rewards = {"reward1", "reward2", "reward3", "reward4", "reward5"}
MainTab:AddSwitch("Auto Claim Rewards", function(Value)
    _G.AutoClaim = Value
    if Value then
        task.spawn(function()
            while _G.AutoClaim do
                for _, rewardID in pairs(rewards) do
                    if not _G.AutoClaim then break end
                    game:GetService("ReplicatedStorage").RemotesEvent.rewardClaim:FireServer(rewardID)
                    task.wait(0.01)
                end
                task.wait(0.01)
            end
        end)
    end
end)

